# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — NEVER commit real keys.

# Google AI Studio (Gemini) API key. SERVER-SIDE ONLY.
# Do NOT prefix with NEXT_PUBLIC_ (that would ship it to the browser bundle).
# When unset, the execution stream falls back to the built-in simulator.
GEMINI_API_KEY=

# Optional: override the Gemini model used for real execution.
GEMINI_MODEL=gemini-2.0-flash
